rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    
    // Helper function to check if the user is authenticated
    function isAuthenticated() {
      return request.auth != null;
    }
    
    // Helper to check if a user matches the target userId
    function isOwner(userId) {
      return isAuthenticated() && request.auth.uid == userId;
    }

    // ==========================================
    // USERS COLLECTION
    // ==========================================
    // - Anyone logged in can read profile details (needed for search, tagging, and messaging)
    // - Users can only write/update their own profile
    match /users/{userId} {
      allow read: if isAuthenticated();
      allow write: if isOwner(userId);
      
      // User Notifications Subcollection
      match /notifications/{notificationId} {
        allow read, update, delete: if isOwner(userId);
        allow create: if isAuthenticated();
      }
    }
    
    // ==========================================
    // CIRCLES COLLECTION
    // ==========================================
    // - Users can create a circle if they set themselves as the owner
    // - Only members can view/read a circle's details
    // - Only the owner can modify (update members, change names) or delete the circle
    match /circles/{circleId} {
      allow create: if isAuthenticated() && request.resource.data.ownerId == request.auth.uid;
      allow read: if isAuthenticated() && request.auth.uid in resource.data.members;
      allow update, delete: if isAuthenticated() && resource.data.ownerId == request.auth.uid;
    }
    
    // ==========================================
    // POSTS COLLECTION
    // ==========================================
    // - Members of a circle can read posts shared to that circle
    // - Users can write posts to a circle if they are members of that circle
    // - Only the original poster can update or delete their post
    match /posts/{postId} {
      allow read: if isAuthenticated() && 
        request.auth.uid in get(/databases/$(database)/documents/circles/$(resource.data.circleId)).data.members;
      
      allow create: if isAuthenticated() && 
        request.resource.data.userId == request.auth.uid &&
        request.auth.uid in get(/databases/$(database)/documents/circles/$(request.resource.data.circleId)).data.members;
      
      allow update, delete: if isAuthenticated() && resource.data.userId == request.auth.uid;

      // Comments Subcollection
      match /comments/{commentId} {
        allow read: if isAuthenticated() && 
          request.auth.uid in get(/databases/$(database)/documents/circles/$(get(/databases/$(database)/documents/posts/$(postId)).data.circleId)).data.members;
        
        allow create: if isAuthenticated() && 
          request.resource.data.userId == request.auth.uid &&
          request.auth.uid in get(/databases/$(database)/documents/circles/$(get(/databases/$(database)/documents/posts/$(postId)).data.circleId)).data.members;
        
        allow update, delete: if isAuthenticated() && resource.data.userId == request.auth.uid;
      }
    }

    // ==========================================
    // STORIES COLLECTION
    // ==========================================
    // - Members of a circle can read stories shared to that circle
    // - Users can write stories to a circle if they are members of that circle
    // - Only the original author can delete their story
    match /stories/{storyId} {
      allow read: if isAuthenticated() && 
        request.auth.uid in get(/databases/$(database)/documents/circles/$(resource.data.circleId)).data.members;
      
      allow create: if isAuthenticated() && 
        request.resource.data.userId == request.auth.uid &&
        request.auth.uid in get(/databases/$(database)/documents/circles/$(request.resource.data.circleId)).data.members;
      
      allow update, delete: if isAuthenticated() && resource.data.userId == request.auth.uid;
    }
    
    // ==========================================
    // CHATS COLLECTION
    // ==========================================
    // - Chat rooms can only be read or modified by their participant users
    // - Subcollection messages can only be sent/read by room participants
    match /chats/{chatId} {
      allow read, write: if isAuthenticated() && request.auth.uid in resource.data.participants;
      allow create: if isAuthenticated() && request.auth.uid in request.resource.data.participants;
      
      match /messages/{messageId} {
        allow read, write: if isAuthenticated() && 
          request.auth.uid in get(/databases/$(database)/documents/chats/$(chatId)).data.participants;
      }
    }
  }
}
